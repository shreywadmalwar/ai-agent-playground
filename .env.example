# Copy this file to .env.local and fill in your real keys.
# .env.local is gitignored — your keys never reach GitHub.
#
# NOTE: anything prefixed VITE_ gets baked into the built JS bundle.
# That's fine for running locally, but do NOT deploy a public build
# with keys in here — for a public deploy, leave these empty and let
# users enter their own keys in the Settings panel (localStorage).

VITE_GEMINI_API_KEY=
VITE_GROQ_API_KEY=
VITE_OPENAI_API_KEY=
